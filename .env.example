# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql://agent12:agent12local@localhost:5432/agent12
DATABASE_URL_TEST=postgresql://agent12:agent12local@localhost:5432/agent12_test

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml):
REDIS_URL=redis://localhost:6379

# ── LLM providers ────────────────────────────────────────────────────────────
# Anthropic — required. Used by all agents unless overridden via provider config.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible providers. All optional — only needed if you want a
# system-default key for one. Most users register their own keys via BYOK
# (user_secrets / tenant_secrets). Each entry corresponds to a provider in
# PROVIDER_REGISTRY (packages/agents/src/providers.ts). Alphabetized.

# DeepSeek — get key at: platform.deepseek.com (free tier available)
# DEEPSEEK_API_KEY=

# Gemini (Google AI Studio) — uses Google's OpenAI-compatible endpoint.
# Get key at: aistudio.google.com/apikey (free tier available)
# GEMINI_API_KEY=

# Kimi (Moonshot AI) — get key at: platform.moonshot.cn
# KIMI_API_KEY=

# Mistral AI — get key at: console.mistral.ai (free tier available)
# MISTRAL_API_KEY=

# OpenAI — get key at: platform.openai.com/api-keys
# OPENAI_API_KEY=

# Together AI — get key at: api.together.ai (free credits on signup)
# TOGETHER_API_KEY=

# Add additional provider keys here as new providers are registered in
# packages/agents/src/providers.ts. Key name must match the provider's
# systemApiKeyEnvVar in PROVIDER_REGISTRY.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for BYOK tenant secrets. Must be exactly 32 bytes, base64 encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required before any tenant provides a BYOK API key.
ENCRYPTION_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# Used for account verification and run completion notifications.
# Resend (resend.com) recommended — simple API, generous free tier.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Agent call logging ────────────────────────────────────────────────────────
# Optional. When set, every agent API call appends a row to this CSV file with
# timing, token counts (including cache hits), and estimated cost in USD.
# Open the file in Excel or Numbers to sort and filter by agent, cost, or duration.
# AGENT_CALL_LOG=packages/evals/logs/agent-calls.csv

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
